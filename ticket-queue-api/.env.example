PORT=8787
REDIS_URL=redis://127.0.0.1:6379
EVENT_ID=demo
SEATS_TOTAL=200
ADMIT_PER_SEC=40
ACTIVE_TTL_SEC=180
TOKEN_SECRET=change-me-in-production
# Comma-separated; include Pages origin + local preview
CORS_ORIGIN=https://mansejin.com,http://localhost:8080,http://127.0.0.1:8080
MAX_QUEUE=5000
# Per-IP rate limits (per minute). Behind Cloudflare Tunnel uses CF-Connecting-IP.
RATE_JOIN_PER_MIN=20
RATE_BOOK_PER_MIN=30
RATE_STATUS_PER_MIN=180
RATE_ADMIN_PER_MIN=10
DATA_DIR=./data

# NAS docker-compose host port (8787 taken by saenggibu on OHOLA-SERVER)
TICKET_QUEUE_HOST_PORT=8790
TQ_DEPLOY_BRANCH=main
TQ_DOCKER_SUDO=1

# Cloudflare — prefer API token automation (see docs/deploy-cloudflare-tunnel.md)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# Runtime token written by provision script (do not commit):
# CLOUDFLARE_TUNNEL_TOKEN=
